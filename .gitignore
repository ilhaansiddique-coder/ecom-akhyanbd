# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example
# Plain `env` (no dot) — Prisma 7 generates this; it holds the same secrets
# as .env. Without this rule a blind `git add` would push prod credentials.
/env
# Stray Flutter scaffold leftover from earlier sessions — the real Flutter
# project lives at D:\Development\AkhiyanFlutterApp.
/lib/

# Migration / sync / one-off ops scripts that hardcode production DB
# connection strings. Keep these on disk for manual ops, never in git.
# (Audited 2026-05-06 — confirmed prod Neon creds inside.) Add new
# entries here whenever you write a script that bakes in credentials,
# or refactor the script to read DATABASE_URL from env instead.
scripts/sync-live-db.mjs
scripts/migrate-to-new-db.sh
scripts/migrate-data.mjs
scripts/create-test-admin.mjs
scripts/create-test-admin-sql.mjs
scripts/create-user-admin.mjs

# vercel
.vercel

# claude code
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
/logs
*.log

# backups
/backups

# pm2
.pm2

# database files & dumps (NEVER commit — may contain prod data)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sql
*.dump
db-exports/
/backups/

# inspection scratch
_inspect*.db
_inspect*.mjs

# Local Capacitor scratch folder (not part of repo)
mobile/

# graphify knowledge graph (regenerable, 10MB+)
graphify-out/
.graphify_*
.agent/

# markdown notes — only README.md and CLAUDE.md tracked policy
*.md
!README.md
CLAUDE.md
