# ============================================
# মা ভেষজ বাণিজ্যালয় — Production Environment
# ============================================

# App
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Database (SQLite - file path relative to project root)
DATABASE_URL="file:./prisma/mavesoj.db"

# Auth - IMPORTANT: Generate a secure secret!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARACTERS_OR_MORE"
NEXTAUTH_URL="https://yourdomain.com"

# Email Configuration (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"  # Use Gmail App Password, not regular password
SMTP_FROM="your-email@gmail.com"
ADMIN_EMAIL="admin@yourdomain.com"

# Optional: For better email deliverability, use a service like:
# - SendGrid: smtp.sendgrid.net (Port 587)
# - Mailgun: smtp.mailgun.org (Port 587)
# - AWS SES: email-smtp.region.amazonaws.com (Port 587)
