generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  // Optional + unique: nullable lets guests place orders without an email.
  // Postgres allows multiple NULLs under a UNIQUE constraint, so phone-only
  // guest users never collide. Email-based login still works for users who
  // do supply one; phone-only users can register later.
  email           String?   @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  password        String
  phone           String?
  address         String?
  role            String    @default("customer")
  avatar          String?
  provider        String?
  providerId      String?   @map("provider_id")
  rememberToken   String?   @map("remember_token")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  orders    Order[]
  wishlists Wishlist[]
  addresses Address[]
  reviews   Review[]
  blogPosts BlogPost[]

  @@index([role])
  @@map("users")
}

model PasswordResetToken {
  email     String    @id
  token     String
  createdAt DateTime? @map("created_at")

  @@map("password_reset_tokens")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  image       String?
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  products         Product[]
  categoryProducts Product[] @relation("ProductCategories")

  @@map("categories")
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  logo      String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  categoryId    Int?      @map("category_id")
  brandId       Int?      @map("brand_id")
  description   String?
  price         Float
  originalPrice Float?    @map("original_price")
  image         String
  images        String?
  badge         String?
  badgeColor    String?   @map("badge_color")
  weight        String?
  stock         Int       @default(0)
  unlimitedStock Boolean? @default(false) @map("unlimited_stock")
  soldCount     Int       @default(0) @map("sold_count")
  version       Int       @default(0) // Optimistic locking — prevents overselling under concurrent purchases
  isActive      Boolean   @default(true) @map("is_active")
  isFeatured    Boolean   @default(false) @map("is_featured")
  hasVariations Boolean?  @default(false) @map("has_variations")
  variationType String?   @map("variation_type") // "ওজন", "সাইজ", "রং", etc.
  customShipping Boolean?  @default(false) @map("custom_shipping")
  shippingCost   Float?    @map("shipping_cost")
  sortOrder     Int       @default(0) @map("sort_order")
  deletedAt     DateTime? @map("deleted_at") // Soft-delete; null = active, set = trashed
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categories  Category[]         @relation("ProductCategories")
  brand       Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  flashSales  FlashSaleProduct[]
  reviews     Review[]
  wishlists   Wishlist[]
  orderItems  OrderItem[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([slug])
  @@index([soldCount])
  @@index([createdAt])
  @@index([categoryId, isActive])
  @@index([brandId, isActive])
  @@index([isActive, soldCount])
  @@index([isActive, sortOrder])
  @@map("products")
}

model FlashSale {
  id        Int       @id @default(autoincrement())
  title     String
  startsAt  DateTime  @map("starts_at")
  endsAt    DateTime  @map("ends_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  products FlashSaleProduct[]

  @@map("flash_sales")
}

model FlashSaleProduct {
  id          Int       @id @default(autoincrement())
  flashSaleId Int       @map("flash_sale_id")
  productId   Int       @map("product_id")
  salePrice   Float     @map("sale_price")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("flash_sale_product")
}

model Order {
  id              Int       @id @default(autoincrement())
  userId          Int?      @map("user_id")
  customerName    String    @map("customer_name")
  customerPhone   String    @map("customer_phone")
  customerEmail   String?   @map("customer_email")
  customerAddress String    @map("customer_address")
  city            String?
  // Real district name parsed from the customer's address via Pathao at
  // order time (background task). Used by /api/v1/collect to override the
  // FB CAPI `ct` field with a usable city instead of the shipping-zone
  // label customers select on the form. Nullable — populates a few seconds
  // after order creation, may be null if Pathao parser is unavailable.
  parsedCity      String?   @map("parsed_city")
  zipCode         String?   @map("zip_code")
  subtotal        Float
  shippingCost    Float     @default(0) @map("shipping_cost")
  discount        Float     @default(0)
  total           Float
  status          String    @default("pending")
  paymentMethod   String    @default("cod") @map("payment_method")
  paymentStatus   String    @default("unpaid") @map("payment_status")
  transactionId   String?   @map("transaction_id")
  orderToken      String?   @unique @map("order_token")
  notes              String?
  courierSent        Boolean   @default(false) @map("courier_sent")
  courierSentAt      DateTime? @map("courier_sent_at") // Set once when first dispatched to courier — never overwritten. Use for daily shipment analytics.
  courierType        String?   @map("courier_type") // "steadfast" | "pathao"
  consignmentId      String?   @map("consignment_id")
  courierStatus      String?   @map("courier_status")
  courierScore       String?   @map("courier_score")
  trackingData       String?   @map("tracking_data")
  fpHash             String?   @map("fp_hash")
  riskScore          Int?      @map("risk_score")
  createdAt          DateTime? @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  fingerprint OrderFingerprint?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([transactionId])
  @@index([riskScore])
  // Dashboard "Courier Sent Orders" + courier-monitor + dashboard analytics
  // all filter on courierSent + courierSentAt. Without indexes Postgres
  // sequentially scans the entire orders table on every page load.
  @@index([courierSentAt])
  @@index([courierSent, courierSentAt])
  // Courier-monitor route uses `consignmentId: { not: null }` with date.
  @@index([consignmentId])
  @@map("orders")
}

model DeviceFingerprint {
  id               Int       @id @default(autoincrement())
  fpHash           String    @unique @map("fp_hash")
  canvasHash       String?   @map("canvas_hash")
  webglHash        String?   @map("webgl_hash")
  audioHash        String?   @map("audio_hash")
  screenResolution String?   @map("screen_resolution")
  platform         String?
  timezone         String?
  languages        String?
  cpuCores         Int?      @map("cpu_cores")
  memoryGb         Float?    @map("memory_gb")
  touchPoints      Int?      @map("touch_points")
  userAgent        String?   @map("user_agent")
  lastIp           String?   @map("last_ip")
  riskScore        Int       @default(0) @map("risk_score")
  status           String    @default("active") // active | blocked | safe
  seenCount        Int       @default(1) @map("seen_count")
  blockReason      String?   @map("block_reason")
  blockedAt        DateTime? @map("blocked_at")
  lastSeenAt       DateTime? @map("last_seen_at")
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  orderFingerprints OrderFingerprint[]

  @@index([status])
  @@index([riskScore])
  @@map("device_fingerprints")
}

model OrderFingerprint {
  id                  Int       @id @default(autoincrement())
  orderId             Int       @unique @map("order_id")
  fpHash              String?   @map("fp_hash")
  ipAddress           String?   @map("ip_address")
  deviceFingerprintId Int?      @map("device_fingerprint_id")
  fillDurationMs      Int?      @map("fill_duration_ms")
  mouseMovements      Int?      @map("mouse_movements")
  pasteDetected       Boolean   @default(false) @map("paste_detected")
  honeypotTriggered   Boolean   @default(false) @map("honeypot_triggered")
  tabSwitches         Int?      @map("tab_switches")
  riskScore           Int       @default(0) @map("risk_score")
  riskFlags           String?   @map("risk_flags")
  createdAt           DateTime? @default(now()) @map("created_at")

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deviceFingerprint DeviceFingerprint? @relation(fields: [deviceFingerprintId], references: [id], onDelete: SetNull)

  @@index([fpHash])
  @@index([ipAddress])
  @@index([riskScore])
  @@map("order_fingerprints")
}

model BlockedIp {
  id        Int       @id @default(autoincrement())
  ipAddress String    @unique @map("ip_address")
  reason    String?
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("blocked_ips")
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int       @map("order_id")
  productId   Int?      @map("product_id")
  productName  String    @map("product_name")
  variantId    Int?      @map("variant_id")
  variantLabel String?   @map("variant_label")
  price        Float
  quantity     Int
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("order_items")
}

model Review {
  id           Int       @id @default(autoincrement())
  productId    Int       @map("product_id")
  userId       Int?      @map("user_id")
  customerName String    @map("customer_name")
  rating       Int
  review       String
  image        String?
  isApproved   Boolean   @default(false) @map("is_approved")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, isApproved])
  @@index([createdAt])
  @@map("reviews")
}

model Wishlist {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  productId Int       @map("product_id")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Coupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  type           String
  value          Float
  minOrderAmount Float     @default(0) @map("min_order_amount")
  maxUses        Int?      @map("max_uses")
  usedCount      Int       @default(0) @map("used_count")
  startsAt       DateTime? @map("starts_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  @@map("coupons")
}

model ShippingZone {
  id            Int       @id @default(autoincrement())
  name          String
  cities        String
  rate          Float
  estimatedDays String?   @map("estimated_days")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@map("shipping_zones")
}

model Address {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  label     String
  name      String
  phone     String
  address   String
  city      String
  zipCode   String?   @map("zip_code")
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Banner {
  id          Int       @id @default(autoincrement())
  title       String
  subtitle    String?
  description String?
  buttonText  String?   @map("button_text")
  buttonUrl   String?   @map("button_url")
  image       String?
  gradient    String?
  emoji       String?
  position    String    @default("hero")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@index([isActive, position])
  @@map("banners")
}

model NavMenu {
  id        Int       @id @default(autoincrement())
  label     String
  url       String
  sortOrder Int       @default(0) @map("sort_order")
  parentId  Int?      @map("parent_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  parent   NavMenu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children NavMenu[] @relation("MenuHierarchy")

  @@index([isActive, parentId])
  @@map("nav_menus")
}

model LandingPage {
  id               Int       @id @default(autoincrement())
  slug             String    @unique
  title            String
  isActive         Boolean   @default(true) @map("is_active")

  // Hero
  heroHeadline     String?   @map("hero_headline")
  heroSubheadline  String?   @map("hero_subheadline")
  heroImage        String?   @map("hero_image")
  heroVideoAutoplay Boolean? @default(false) @map("hero_video_autoplay")
  heroCta          String?   @map("hero_cta")
  heroTrustText    String?   @map("hero_trust_text")
  heroBadge        String?   @map("hero_badge")

  // Problem
  problemTitle     String?   @map("problem_title")
  problemPoints    String?   @map("problem_points")

  // Sections (JSON strings)
  productsTitle    String?   @map("products_title")
  productsSub      String?   @map("products_subtitle")
  featuresTitle    String?   @map("features_title")
  featuresImage    String?   @map("features_image")
  features         String?
  testimonialsTitle String?  @map("testimonials_title")
  testimonialsMode String?   @default("custom") @map("testimonials_mode")
  testimonials     String?
  howItWorksTitle  String?   @map("how_it_works_title")
  howItWorksSub    String?   @map("how_it_works_subtitle")
  howItWorks       String?   @map("how_it_works")
  faqTitle         String?   @map("faq_title")
  faq              String?

  // Products (JSON: [{product_id, quantity}])
  products         String?

  // Checkout
  checkoutTitle    String?   @map("checkout_title")
  checkoutSubtitle String?   @map("checkout_subtitle")
  checkoutBtnText  String?   @map("checkout_btn_text")
  customShipping   Boolean?  @default(false) @map("custom_shipping")
  shippingCost     Float?    @default(60) @map("shipping_cost")
  showEmail        Boolean?  @default(false) @map("show_email")
  showCity         Boolean?  @default(true) @map("show_city")
  guaranteeText    String?   @map("guarantee_text")
  successMessage   String?   @map("success_message")

  // SEO
  metaTitle        String?   @map("meta_title")
  metaDescription  String?   @map("meta_description")

  // WhatsApp
  whatsapp         String?   @map("whatsapp")
  // Per-page override of the global widget.contact_mode setting.
  // "inherit" (default) → use site setting, "whatsapp" → force WhatsApp, "phone" → force phone call.
  contactMode      String?   @default("inherit") @map("contact_mode")

  // Section Visibility (JSON string: {"hero":true,"problem":true,...})
  sectionVisibility String?  @map("section_visibility")

  // Style
  primaryColor     String?   @default("#0f5931") @map("primary_color")

  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  @@map("landing_pages")
}

model BlogPost {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String
  image           String?
  category        String?
  tags            String?   @db.Text
  readTime        Int?      @map("read_time")
  featured        Boolean   @default(false)
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description") @db.Text
  metaKeywords    String?   @map("meta_keywords") @db.Text
  ogImage         String?   @map("og_image")
  authorId        Int?      @map("author_id")
  isPublished     Boolean   @default(false) @map("is_published")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([isPublished])
  @@index([slug])
  @@index([featured])
  @@index([category])
  @@map("blog_posts")
}

model SiteSetting {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     String?
  group     String    @default("general")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("site_settings")
}

model FormSubmission {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String    @default("unread") // unread, read, replied
  notes     String?   // admin notes
  createdAt DateTime? @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("form_submissions")
}

model IncompleteOrder {
  id           Int       @id @default(autoincrement())
  phone        String    @unique
  name         String?
  email        String?
  address      String?
  city         String?
  zipCode      String?   @map("zip_code")
  notes        String?
  cartItems    String    @map("cart_items") // JSON array: [{product_id, variant_id, name, price, quantity, image, variant_label}]
  subtotal     Float     @default(0)
  shippingCost Float     @default(0) @map("shipping_cost")
  total        Float     @default(0)
  userId       Int?      @map("user_id")
  source       String?   // "checkout" | "lp:slug" — which form captured it
  convertedAt  DateTime? @map("converted_at") // set when matching order placed
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  @@index([phone])
  @@index([convertedAt])
  @@index([updatedAt])
  @@map("incomplete_orders")
}

model ProductVariant {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  label         String
  price         Float
  originalPrice Float?    @map("original_price")
  sku           String?
  stock         Int       @default(0)
  unlimitedStock Boolean? @default(false) @map("unlimited_stock")
  image         String?
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  version       Int       @default(0)
  createdAt     DateTime? @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

// Shortlinks: admin-defined slug → arbitrary URL redirect. Used for shareable
// links (e.g. /schoolbag → /shop?category=29). Resolved by the catch-all
// /[slug] route — slug must not collide with any existing top-level static
// route (validated at create time).
model Shortlink {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  targetUrl   String    @map("target_url")
  hits        Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  clicks      ShortlinkClick[]
  @@index([slug])
  @@map("shortlinks")
}

// One row per click. The lightweight Shortlink.hits counter still gets bumped
// for fast list-view stats; this table is the detail log used by the
// analytics page (timeline, country/browser/OS/device/source breakdowns).
//
// We intentionally store only a TRUNCATED ip (last octet zeroed for IPv4 /
// last 80 bits zeroed for IPv6) so we can dedupe loosely + group by network
// without retaining a full PII identifier.
model ShortlinkClick {
  id           Int       @id @default(autoincrement())
  shortlinkId  Int       @map("shortlink_id")
  shortlink    Shortlink @relation(fields: [shortlinkId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now()) @map("created_at")
  ipTrunc      String?   @map("ip_trunc")
  country      String?
  referer      String?
  // Parsed source label: "facebook" / "instagram" / "google" / "direct" / etc.
  // Derived from referer + utm_source so we can group cleanly on the chart.
  source       String?
  utmSource    String?   @map("utm_source")
  utmMedium    String?   @map("utm_medium")
  utmCampaign  String?   @map("utm_campaign")
  browser      String?
  os           String?
  device       String?   // "mobile" | "tablet" | "desktop"
  @@index([shortlinkId])
  @@index([createdAt])
  @@map("shortlink_clicks")
}
